# ACAPS API key — register at https://api.acaps.org/register/
ACAPS_API_KEY=your_acaps_token_here

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# UCDP GED API token (optional — local CSV cache works without it)
# Register at https://ucdp.uu.se/apidocs/
UCDP_API_TOKEN=your_ucdp_token_here

# GeoNames username, used for city population lookup (free account)
# Register at https://www.geonames.org/login
GEONAMES_USERNAME=your_geonames_username

# EIA API key, used for live Brent crude oil price (commodity price adjustment)
# Register at https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# FRED API key, used for live food-basket commodity prices (wheat/corn/rice/soybean oil)
# Register at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ─── Abuse protection (see security.py — all optional, safe defaults) ────────
# Set API_KEY to require an X-API-Key header on the endpoints that spend money
# or third-party quota. LEAVE UNSET for a public deployment: the browser app
# does not send the header, so setting this locks the live UI out of AI/live
# data. Rate limits below apply either way.
# API_KEY=

# Comma-separated CORS allowlist ("*" allows any origin).
# ALLOWED_ORIGINS=https://ercf-production.up.railway.app,http://localhost:8000

# RATE_LIMIT_PER_MIN=120            per-IP requests/min against /api/*
# EXTERNAL_RATE_LIMIT_PER_HOUR=120  per-IP requests/hour against live-data endpoints
# LLM_RATE_LIMIT_PER_HOUR=10        per-IP paid Anthropic calls/hour
# LLM_DAILY_CAP=500                 global paid Anthropic calls/day (0 = never call)
